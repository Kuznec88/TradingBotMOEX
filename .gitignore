# Python bytecode
__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/
env/
fix_engine/.venv/

# Environment variables
.env
.env.*

# Logs / temp / backups
*.log
*.tmp
*.bak
# SQLite journal (не коммитить)
*.db-shm
*.db-wal
# single-instance lock (создаётся при старте раннера)
fix_engine/log/fix_engine_runtime.lock

# T-Invest sandbox token (optional override; prefer env TINKOFF_SANDBOX_TOKEN)
fix_engine/settings.local.cfg
fix_engine/settings.runtime.cfg
*.db
*.sqlite3

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
/dist/
/build/

# IDE/editor
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db

# Runtime / local artifacts (regenerated on run)
fix_engine/log/
fix_engine/store/
trade_economics.db
last_session*.json
